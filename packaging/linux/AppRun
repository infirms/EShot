#!/usr/bin/env bash
set -euo pipefail

appdir="${APPDIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
source "${appdir}/usr/lib/eshot/runtime-common.sh"

installed_appimage="$(eshot_installed_appimage_path)"
desktop_file="$(eshot_desktop_file_path)"
data_home="${XDG_DATA_HOME:-${HOME}/.local/share}"
installed_icon="${data_home}/icons/hicolor/scalable/apps/io.github.benoks.EShot.svg"

install_desktop_entry() {
  local source_desktop="${appdir}/usr/share/applications/io.github.benoks.EShot.desktop"
  local escaped_path="${installed_appimage//\\/\\\\}"
  escaped_path="${escaped_path//\"/\\\"}"

  mkdir -p "$(dirname "${desktop_file}")" "$(dirname "${installed_icon}")"
  awk -v executable="${escaped_path}" '
    /^Exec=/ { print "Exec=/usr/bin/env ESHOT_DESKTOP_LAUNCH=1 \"" executable "\""; next }
    { print }
  ' "${source_desktop}" >"${desktop_file}.new"
  mv -f -- "${desktop_file}.new" "${desktop_file}"
  chmod 0644 "${desktop_file}"
  cp -f -- "${appdir}/usr/share/icons/hicolor/scalable/apps/io.github.benoks.EShot.svg" "${installed_icon}"
  chmod 0644 "${installed_icon}"

  if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "$(dirname "${desktop_file}")" >/dev/null 2>&1 || true
  fi
  if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f -t "${data_home}/icons/hicolor" >/dev/null 2>&1 || true
  fi
  if command -v kbuildsycoca6 >/dev/null 2>&1; then
    kbuildsycoca6 --noincremental >/dev/null 2>&1 || true
  fi
}

integrate_appimage() {
  if [[ -z "${APPIMAGE:-}" || ! -f "${APPIMAGE}" ]]; then
    return 0
  fi

  mkdir -p "$(dirname "${installed_appimage}")"
  if [[ "$(readlink -f "${APPIMAGE}")" != "$(readlink -m "${installed_appimage}")" ]]; then
    cp -f -- "${APPIMAGE}" "${installed_appimage}.new"
    chmod 0755 "${installed_appimage}.new"
    mv -f -- "${installed_appimage}.new" "${installed_appimage}"
  else
    chmod 0755 "${installed_appimage}"
  fi
  install_desktop_entry
}

if [[ "${1:-}" == "--integrate-only" ]]; then
  integrate_appimage
  exit 0
fi

if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] \
   && [[ "${XDG_CURRENT_DESKTOP:-${XDG_SESSION_DESKTOP:-}}" == *KDE* ]]; then
  export QT_QPA_PLATFORM=xcb
  export ESHOT_WAYLAND_XWAYLAND_OVERLAY=1
fi

export ESHOT_APPDIR="${appdir}"
exec "${appdir}/usr/bin/EShot" "$@"
