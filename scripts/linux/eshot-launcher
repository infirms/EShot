#!/usr/bin/env bash
set -euo pipefail

bindir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${bindir}/../lib/eshot/runtime-common.sh"

# KDE and GNOME expose a complete multi-monitor XWayland coordinate space.
# Prefer it for one responsive selection canvas, but keep native Wayland as a
# fallback on sessions where XWayland is intentionally disabled.
if [[ "$(eshot_xwayland_overlay_enabled)" == "1" ]]; then
  export QT_QPA_PLATFORM='xcb;wayland'
  export ESHOT_WAYLAND_XWAYLAND_OVERLAY=1
fi

if [[ "${ESHOT_SYSTEMD_CHILD:-0}" != "1" ]] && command -v systemd-run >/dev/null 2>&1; then
  if systemctl --user is-active --quiet eshot.service 2>/dev/null; then
    exec "${bindir}/EShot" "$@"
  fi
  exec systemd-run --user --unit=eshot --collect --property=Type=exec \
    --setenv=ESHOT_SYSTEMD_CHILD=1 \
    --setenv="QT_QPA_PLATFORM=${QT_QPA_PLATFORM:-}" \
    --setenv="ESHOT_WAYLAND_XWAYLAND_OVERLAY=${ESHOT_WAYLAND_XWAYLAND_OVERLAY:-0}" \
    "${bindir}/EShot" "$@"
fi

exec "${bindir}/EShot" "$@"
